DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_pos"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# --- Pour Vercel + Supabase : utilise le POOLER (port 6543), pas la connexion directe ---
# Supabase Dashboard → Settings → Database → Connection string → "Transaction" mode
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Sur Vercel: NEXTAUTH_URL = https://ton-domaine.vercel.app
# Optionnel: SITE_URL pour les QR codes (sinon VERCEL_URL ou NEXTAUTH_URL sont utilisés)
# SITE_URL="https://pos-restaurant-herm.vercel.app"
