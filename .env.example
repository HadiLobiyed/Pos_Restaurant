# Obligatoire : Prisma exige DATABASE_URL + DIRECT_URL (même valeur en local si une seule base)
DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_pos?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/restaurant_pos?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# --- Supabase (recommandé : évite "db push" qui bloque sur le pooler seul) ---
# 1) DATABASE_URL = pooler TRANSACTION (port 6543), avec pgbouncer
#    Dashboard → Database → Connection string → URI → Mode "Transaction"
#    Ex: postgresql://postgres.[REF]:[PWD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# 2) DIRECT_URL — pour prisma db push / migrate :
#    - Idéal : "Direct connection" (db.[REF].supabase.co:5432)
#    - Si erreur P1001 (PC / box / IPv6) : utilise "Session pool" (même hôte pooler, port 5432)
#      Dashboard → Database → Connection string → Session pooler
#
# Sur Vercel : ajoute DATABASE_URL et DIRECT_URL dans Settings → Environment Variables
# Optionnel: SITE_URL pour les QR codes
# SITE_URL="https://ton-app.vercel.app"
