generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App / Vercel : souvent le pooler Supabase (:6543 + pgbouncer)
  url       = env("DATABASE_URL")
  // db push / migrate : connexion DIRECTE (db.xxx.supabase.co:5432) — évite les blocages sur le pooler
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum OrderChannel {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
}

/// Ligne unique (id = "default") — horaires d’ouverture par jour (JSON)
model RestaurantSettings {
  id             String   @id @default("default")
  /// { "0": { "closed": false, "ranges": [{ "start": "12:00", "end": "14:30" }] }, ... } clés 0=dimanche … 6=samedi
  openingHours Json?
  updatedAt      DateTime @updatedAt
}

model Category {
  id         String     @id @default(cuid())
  name       String
  menuItems  MenuItem[]
  createdAt  DateTime   @default(now())
}

model MenuItem {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  image       String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  visible     Boolean   @default(true)
  stock       Int?      // null = pas de suivi, sinon quantité restante (ex: boissons)
  barcode     String?   // code-barres
  orderItems  OrderItem[]
  createdAt   DateTime  @default(now())
}

model Table {
  id              String    @id @default(cuid())
  number          Int       @unique
  qrCode          String?   // base64 or URL path
  reserved        Boolean   @default(false)
  reservationTime DateTime?
  orders          Order[]
}

model Order {
  id              String        @id @default(cuid())
  tableId         String?
  table           Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  channel         OrderChannel  @default(DINE_IN)
  /// Code affiché au client (ex. CMD-847291) — à emporter / livraison / QR
  publicCode      String?       @unique
  customerName    String?
  customerPhone   String?
  customerAddress String?
  status          OrderStatus   @default(PENDING)
  orderItems      OrderItem[]
  payment         Payment?
  createdAt       DateTime      @default(now())
}

model TableReservation {
  id               String   @id @default(cuid())
  name             String
  phone            String
  people           Int
  /// Ancien champ libre (avant date/heure structurées)
  preferredDate    String?
  /// Date de réservation YYYY-MM-DD (obligatoire pour les nouvelles demandes)
  reservationDate  String?
  /// Créneau HH:mm (aligné sur les plages du restaurant)
  reservationTime  String?
  message          String?
  createdAt        DateTime @default(now())
  /// Traitée par l’équipe (masque le badge « nouvelle »)
  handled          Boolean  @default(false)
}

model OrderItem {
  id         String         @id @default(cuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem       @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity   Int
  comment    String?
  status     OrderItemStatus @default(PENDING)
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  total     Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(UNPAID)
  createdAt DateTime      @default(now())
}
